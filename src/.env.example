# Server
NODE_ENV=development
PORT=3000

# Comma-separated API keys for Authorization: Bearer <key> or x-api-key header
PLATFORM_API_KEYS=your-long-random-api-key

# Redis (required for Bull)
REDIS_URL=redis://127.0.0.1:6379

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Gmail OAuth2 (use refresh token for server-to-server; run OAuth flow once offline)
GMAIL_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
# Optional: path to OAuth client JSON (e.g. ./credentials.json) — never commit this file
GMAIL_OAUTH_CLIENT_JSON_PATH=

# Optional Gmail tuning
GMAIL_USER_EMAIL=me@gmail.com
GMAIL_MAX_MESSAGES=15

# Deal finder: comma-separated URLs to scan when payload omits urls
DEAL_SCAN_URLS=https://news.ycombinator.com,https://www.reddit.com/r/buildapcsales/

# Notifications
NOTIFY_WEBHOOK_URL=

# Job schedules (cron expressions for Bull repeatables; empty disables)
EMAIL_SCAN_CRON=0 */6 * * *
DEAL_SCAN_CRON=0 */4 * * *
